# Sightline Environment Variables Example
# Copy this file to .env and fill in your actual values
# Django Settings
DEBUG=1
SECRET_KEY=your-django-secret-key
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1 [::1] backend

# API Keys
GEMINI_API_KEY=your-gemini-api-key

# Database Settings (Supabase)
# The "Worker" URL (Speed & Concurrency)
DATABASE_URL=postgresql://postgres.[REF]:[PASS]@[HOST]:6543/postgres?pgbouncer=true

# The "Migration" URL (Safety & Locks)
DIRECT_URL=postgresql://postgres.[REF]:[PASS]@[HOST]:5432/postgres

# Keep this at 0 for daily use
MIGRATION_MODE=0

# Celery & Redis (Upstash)
# Use the 'rediss://' (with double 's') from Upstash for TLS security
CELERY_BROKER_URL=rediss://default:your_password@your_endpoint.upstash.io:6379?ssl_cert_reqs=none
CELERY_RESULT_BACKEND=rediss://default:your_password@your_endpoint.upstash.io:6379?ssl_cert_reqs=none

CRON_SECRET=some-long-random-secret-string

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_URL=http://backend:8000
BASE_URL=http://localhost:3000

# Supabase S3 Storage (Required for persistent screenshots)
USE_S3=1
AWS_ACCESS_KEY_ID=your-s3-access-key-id
AWS_SECRET_ACCESS_KEY=your-s3-secret-key
AWS_STORAGE_BUCKET_NAME=screenshots
AWS_S3_ENDPOINT_URL=https://your-project-ref.supabase.co/storage/v1/s3
AWS_S3_REGION_NAME=region